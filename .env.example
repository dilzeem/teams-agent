# Azure AD Application Registration Details
CLIENT_ID="YOUR_AZURE_AD_APP_CLIENT_ID"
CLIENT_SECRET="YOUR_AZURE_AD_APP_CLIENT_SECRET"
TENANT_ID="YOUR_AZURE_AD_TENANT_ID"

# Application Configuration
# The redirect path used in your Azure AD app registration.
# Example: /getAToken
# This should match the REDIRECT_PATH in app/main.py
APP_REDIRECT_PATH="/getAToken"

# Microsoft Graph API Scopes (space separated)
# Example: "User.Read Chat.ReadWrite"
# These should match GRAPH_SCOPES in app/main.py
GRAPH_SCOPES="User.Read Chat.ReadWrite"

# Flask specific (optional, Flask defaults are usually fine for local dev)
# FLASK_APP="app/main.py"
# FLASK_ENV="development" # Enables debug mode

# For local development if not using HTTPS (NOT FOR PRODUCTION)
# OAUTHLIB_INSECURE_TRANSPORT='1'
